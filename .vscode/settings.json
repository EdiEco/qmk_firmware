// Place your settings in this file to overwrite default and user settings.
{
    // Unofficially, QMK uses spaces for indentation
    "editor.insertSpaces": true,
    // Configure glob patterns for excluding files and folders.
    "files.exclude": {
        "**/.build": true,
        "**/*.hex": true,
        "**/*.bin": true
    },
    "files.associations": {
        "*.h": "c",
        "*.c": "c",
        "*.inc": "c",
        "*.cpp": "cpp",
        "*.hpp": "cpp",
        "xstddef": "c",
        "type_traits": "c",
        "utility": "c",
        "ranges": "c",
        "hash_map": "c",
        "hash_set": "c",
        "bitset": "c",
        "chrono": "c",
        "algorithm": "c",
        "*.tcc": "c",
        "cmath": "c",
        "random": "c",
        "istream": "c",
        "limits": "c",
        "memory": "c",
        "numeric": "c",
        "ostream": "c",
        "streambuf": "c",
        "regex": "c",
        "tuple": "c",
        "cctype": "c",
        "string": "c",
        "atomic": "c",
        "cstdint": "c"
    },
    "[markdown]": {
        "editor.trimAutoWhitespace": false,
        "files.trimTrailingWhitespace": false
    }
}
